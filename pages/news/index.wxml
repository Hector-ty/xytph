<app-nav></app-nav>
<view class="page-shell news-page">
  <view class="safe-top"></view>
  <view class="topbar">
    <button class="back-button" bindtap="goBack">‹</button>
    <view class="topbar-title">资讯中心</view>
    <view class="topbar-space"></view>
  </view>

  <view class="page-content">
    <view class="featured-news" bindtap="openArticle" data-id="{{news[0].id}}">
      <image src="/assets/brand/campus-building.jpg" mode="aspectFill"></image>
      <view class="featured-overlay"></view>
      <view class="featured-copy">
        <view class="featured-tag">{{news[0].tag}}</view>
        <view class="featured-title">{{news[0].title}}</view>
        <view class="featured-note">{{news[0].summary}}</view>
      </view>
    </view>

    <view class="section-title-row">
      <view class="section-title">最新动态</view>
      <view class="section-note">绿色校园正在发生</view>
    </view>

    <view class="news-list panel">
      <view class="news-row" wx:for="{{news}}" wx:key="id" bindtap="openArticle" data-id="{{item.id}}">
        <view class="news-date">
          <view>{{item.date}}</view>
          <text>{{item.tag}}</text>
        </view>
        <view class="news-copy">
          <view class="news-title">{{item.title}}</view>
          <view class="news-summary">{{item.summary}}</view>
        </view>
        <view class="news-arrow">›</view>
      </view>
    </view>
  </view>
</view>
