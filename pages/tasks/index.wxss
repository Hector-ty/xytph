.tasks-page {
  background: linear-gradient(180deg, #e5f5ec 0%, #f6f9f3 360rpx);
}

.tasks-topbar {
  padding-right: 190rpx;
}

.rules-button {
  width: 74rpx !important;
  min-width: 74rpx;
  max-width: 74rpx;
  height: 58rpx;
  border: 2rpx solid #b7d8c5;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
  color: #2e7659;
  background: #fff;
}

.tasks-content {
  padding-top: 12rpx;
}

.summary-panel {
  position: relative;
  height: 230rpx;
  padding: 30rpx;
  border-radius: 18rpx;
  overflow: hidden;
  display: flex;
  justify-content: space-between;
  color: #fff;
  background: #197f5c;
  box-shadow: 0 16rpx 34rpx rgba(24, 111, 79, 0.18);
}

.summary-copy {
  position: relative;
  z-index: 2;
}

.summary-kicker {
  font-size: 21rpx;
  color: #cce9dc;
}

.summary-title {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 900;
}

.summary-note {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #cce9dc;
}

.summary-score {
  position: relative;
  z-index: 2;
  width: 126rpx;
  height: 126rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.12);
}

.summary-score-value {
  font-size: 30rpx;
  font-weight: 900;
  color: #f6db76;
}

.summary-score-label {
  margin-top: 5rpx;
  font-size: 17rpx;
  color: #d6eee3;
}

.summary-hill {
  position: absolute;
  bottom: -100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hill-one {
  left: -80rpx;
  width: 420rpx;
  height: 210rpx;
}

.hill-two {
  right: -70rpx;
  width: 360rpx;
  height: 180rpx;
  background: rgba(239, 202, 91, 0.1);
}

.zone-tabs {
  width: calc(100% + 56rpx);
  margin: 28rpx 0 0 -28rpx;
  white-space: nowrap;
}

.zone-tabs-inner {
  padding: 2rpx 28rpx 12rpx;
  display: inline-flex;
  gap: 12rpx;
}

.zone-tab {
  width: auto !important;
  min-width: 128rpx;
  height: 66rpx;
  padding: 0 18rpx 0 10rpx;
  border: 2rpx solid #dce9e1;
  border-radius: 34rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 9rpx;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
  color: #718379;
  background: #fff;
  text-align: center;
  white-space: nowrap;
}

.zone-tab-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17rpx;
  font-weight: 900;
  color: #fff;
}

.zone-banner {
  position: relative;
  min-height: 126rpx;
  margin-top: 14rpx;
  padding: 22rpx 23rpx;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
}

.zone-banner-icon {
  width: 72rpx;
  height: 72rpx;
  margin-right: 16rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  background: #fff;
}

.zone-banner-copy {
  position: relative;
  z-index: 1;
}

.zone-banner-title {
  font-size: 28rpx;
  font-weight: 900;
}

.zone-banner-note {
  margin-top: 8rpx;
  font-size: 19rpx;
  color: #637c70;
}

.zone-banner-leaf {
  position: absolute;
  right: -28rpx;
  bottom: -32rpx;
  width: 160rpx;
  height: 100rpx;
  border: 12rpx solid;
  border-radius: 100% 0 100% 0;
  opacity: 0.12;
  transform: rotate(-16deg);
}

.task-list {
  margin-top: 20rpx;
}

.task-card {
  position: relative;
  min-height: 176rpx;
  margin-bottom: 16rpx;
  padding: 24rpx 22rpx;
  display: flex;
  align-items: flex-start;
}

.task-icon {
  flex: none;
  width: 78rpx;
  height: 78rpx;
  margin-right: 16rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.task-main {
  min-width: 0;
  flex: 1;
  padding-right: 140rpx;
}

.task-heading-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.task-name {
  overflow: hidden;
  font-size: 27rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-points {
  flex: none;
  font-size: 22rpx;
  font-weight: 900;
}

.task-subtitle {
  margin-top: 10rpx;
  overflow: hidden;
  font-size: 20rpx;
  color: #73877d;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-meta-row {
  margin-top: 17rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.task-type {
  flex: none;
  padding: 7rpx 13rpx;
  border-radius: 20rpx;
  font-size: 17rpx;
  color: #527164;
  background: #eef5f0;
}

.task-progress {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 16rpx;
  color: #7c9086;
}

.task-progress-bar {
  min-width: 60rpx;
  height: 8rpx;
  flex: 1;
  border-radius: 8rpx;
  overflow: hidden;
  background: #e5ece8;
}

.task-progress-fill {
  height: 100%;
  border-radius: inherit;
}

.task-status {
  position: absolute;
  top: 24rpx;
  right: 20rpx;
  min-width: 86rpx;
  padding: 10rpx 12rpx;
  border-radius: 24rpx;
  font-size: 18rpx;
  font-weight: 800;
  text-align: center;
  color: #fff;
  background: #8fa69a;
}

.task-claim-button {
  position: absolute;
  right: 20rpx;
  bottom: 22rpx;
  width: 132rpx !important;
  min-width: 132rpx;
  max-width: 132rpx;
  height: 48rpx;
  border-radius: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 800;
  color: #82958b;
  background: #e7eee9;
}

.task-claim-button.ready {
  color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(41, 130, 87, 0.18);
}

.status-COMPLETED {
  color: #2b7c5d;
  background: #dff2e8;
}

.status-READY_TO_CLAIM {
  color: #1d7655;
  background: #dff6c8;
}

.status-PENDING_REVIEW {
  color: #a16d16;
  background: #fff0c8;
}

.status-REJECTED {
  color: #aa5242;
  background: #f7dfd9;
}
