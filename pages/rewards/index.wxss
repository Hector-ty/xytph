.rewards-page {
  background: #f7f7f0;
}

.reward-hero {
  min-height: 420rpx;
  background: linear-gradient(180deg, #dff4e7 0%, #eff6da 100%);
}

.reward-topbar {
  height: 110rpx;
  padding-right: 190rpx;
}

.reward-title {
  font-size: 38rpx;
  font-weight: 900;
}

.reward-subtitle {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #668274;
}

.reward-rule-button {
  flex: none;
  width: 128rpx !important;
  min-width: 128rpx;
  max-width: 128rpx;
  height: 56rpx;
  border: 2rpx solid #b8d9c6;
  border-radius: 29rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19rpx;
  line-height: 1;
  font-weight: 700;
  color: #276f54;
  background: rgba(255, 255, 255, 0.8);
}

.balance-card {
  position: relative;
  height: 240rpx;
  margin: 12rpx 28rpx 0;
  padding: 32rpx;
  border-radius: 18rpx;
  overflow: hidden;
  color: #fff;
  background: #177c5b;
  box-shadow: 0 16rpx 34rpx rgba(24, 111, 79, 0.2);
}

.balance-label {
  position: relative;
  z-index: 2;
  font-size: 21rpx;
  color: #d3ebdf;
}

.balance-value {
  position: relative;
  z-index: 2;
  margin-top: 8rpx;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 900;
  color: #f8df74;
}

.balance-rank {
  position: relative;
  z-index: 2;
  margin-top: 13rpx;
  font-size: 18rpx;
  color: #c9e7da;
}

.balance-mascot {
  position: absolute;
  right: 12rpx;
  bottom: -58rpx;
  z-index: 2;
  width: 220rpx;
  height: 310rpx;
  transform: rotate(6deg);
}

.balance-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.circle-one {
  width: 320rpx;
  height: 320rpx;
  right: -120rpx;
  top: -150rpx;
}

.circle-two {
  width: 220rpx;
  height: 220rpx;
  left: -110rpx;
  bottom: -160rpx;
  background: rgba(249, 211, 91, 0.1);
}

.reward-content {
  margin-top: -24rpx;
  border-radius: 26rpx 26rpx 0 0;
  background: #f7f7f0;
}

.reward-tabs {
  height: 76rpx;
  padding: 7rpx;
  border: 2rpx solid #e0e9e2;
  border-radius: 40rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  align-items: center;
  overflow: hidden;
  background: #fff;
}

.reward-tabs button {
  width: 100% !important;
  min-width: 0;
  height: 62rpx;
  margin: 0;
  padding: 0 8rpx;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 700;
  color: #74867c;
  overflow: hidden;
  text-align: center;
  white-space: nowrap;
}

.reward-tabs button.active {
  color: #fff;
  background: #19845e;
}

.exchange-point-card {
  min-height: 96rpx;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border: 2rpx solid rgba(25, 132, 94, 0.12);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(32, 105, 76, 0.08);
}

.exchange-point-icon {
  flex: none;
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  color: #fff;
  background: #19845e;
}

.exchange-point-copy {
  min-width: 0;
  flex: 1;
}

.exchange-point-title {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #17382b;
}

.exchange-point-note {
  margin-top: 6rpx;
  overflow: hidden;
  font-size: 18rpx;
  line-height: 1.25;
  color: #71847b;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.exchange-point-button {
  flex: none;
  width: 98rpx !important;
  height: 50rpx;
  margin: 0;
  padding: 0;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 900;
  color: #fff;
  background: #19845e;
}

.reward-tip {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  background: #fff0c8;
}

.reward-tip-icon {
  flex: none;
  width: 58rpx;
  height: 58rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  color: #a66d16;
  background: #fff;
}

.reward-tip-title {
  font-size: 22rpx;
  font-weight: 800;
  color: #77561b;
}

.reward-tip-note {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #957a48;
}

.reward-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.reward-card {
  overflow: hidden;
}

.reward-card-wide {
  grid-column: 1 / -1;
}

.reward-visual {
  position: relative;
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #eaf7ed;
}

.reward-image {
  width: 100%;
  height: 100%;
}

.reward-card-wide .reward-visual {
  height: 270rpx;
}

.reward-stock {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 10rpx;
  border-radius: 18rpx;
  font-size: 15rpx;
  color: #607a6d;
  background: rgba(255, 255, 255, 0.74);
}

.reward-card-copy {
  padding: 18rpx 17rpx 17rpx;
}

.reward-name {
  min-height: 64rpx;
  font-size: 23rpx;
  line-height: 1.4;
  font-weight: 800;
}

.reward-note {
  min-height: 48rpx;
  margin-top: 4rpx;
  font-size: 17rpx;
  line-height: 1.35;
  color: #829087;
}

.reward-bottom {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.reward-card-wide .reward-card-copy {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  grid-template-areas:
    "name bottom"
    "note bottom";
  column-gap: 20rpx;
  align-items: center;
}

.reward-card-wide .reward-name {
  grid-area: name;
  min-height: 0;
}

.reward-card-wide .reward-note {
  grid-area: note;
  min-height: 0;
}

.reward-card-wide .reward-bottom {
  grid-area: bottom;
  margin-top: 0;
  min-width: 220rpx;
}

.reward-points {
  font-size: 28rpx;
  font-weight: 900;
  color: #e18820;
}

.reward-points text {
  font-size: 17rpx;
}

.redeem-button {
  width: 108rpx !important;
  min-width: 82rpx;
  height: 48rpx;
  border-radius: 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 800;
  color: #fff;
  background: #19845e;
}

.redeem-button[disabled] {
  color: #99a69f;
  background: #e6ece8;
}

.record-list {
  margin-top: 22rpx;
}

.record-card {
  min-height: 120rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
}

.record-icon {
  flex: none;
  width: 72rpx;
  height: 72rpx;
  margin-right: 14rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
  color: #a66d16;
  background: #fff0c8;
}

.record-copy {
  min-width: 0;
  flex: 1;
}

.record-name {
  font-size: 24rpx;
  font-weight: 800;
}

.record-meta {
  margin-top: 7rpx;
  font-size: 18rpx;
  color: #7c8d84;
}

.record-code {
  width: 105rpx !important;
  flex: none;
  padding: 12rpx 17rpx;
  border-radius: 26rpx;
  font-size: 18rpx;
  font-weight: 800;
  color: #197551;
  background: #e1f2e8;
}

.record-code-panel {
  margin-top: 14rpx;
  padding: 16rpx;
  border: 2rpx solid rgba(25, 132, 94, 0.12);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  background: #f4fbf7;
}

.record-qr {
  box-sizing: content-box;
  flex: none;
  width: 165rpx;
  height: 165rpx;
  margin-right: 16rpx;
  padding: 8rpx;
  border: 0;
  border-radius: 10rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(32, 105, 76, 0.08);
}

.qr-grid {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.qr-row {
  min-height: 0;
  flex: 1;
  display: flex;
}

.qr-cell {
  min-width: 0;
  flex: 1;
  background: #ffffff;
}

.qr-cell-dark {
  background: #102d22;
}

.record-code-copy {
  min-width: 0;
  flex: 1;
}

.record-code-label {
  font-size: 18rpx;
  font-weight: 800;
  color: #6f8178;
}

.record-code-value {
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.1;
  font-weight: 900;
  color: #17382b;
  letter-spacing: 0;
}

.record-code-note {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.35;
  color: #6f8178;
}

.code-preview-overlay {
  position: fixed;
  inset: 0;
  z-index: 1200;
  min-height: 100vh;
  padding: 120rpx 42rpx 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(13, 50, 33, 0.56);
}

.code-preview-card {
  width: 100%;
  max-width: 620rpx;
  padding: 34rpx 30rpx 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 24rpx;
  text-align: center;
  background: linear-gradient(180deg, #f7fff9 0%, #e7f6eb 100%);
  box-shadow: 0 30rpx 70rpx rgba(7, 63, 38, 0.3);
}

.code-preview-title {
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #123d2b;
}

.code-preview-name {
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.35;
  color: #5e7b6e;
}

.code-preview-qr {
  box-sizing: content-box;
  width: 363rpx;
  height: 363rpx;
  margin: 24rpx auto 20rpx;
  padding: 14rpx;
  border: 0;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(32, 105, 76, 0.12);
}

.code-preview-label {
  font-size: 19rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #6f8178;
}

.code-preview-value {
  margin-top: 8rpx;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 900;
  color: #17382b;
  letter-spacing: 0;
}

.code-preview-note {
  margin: 14rpx auto 0;
  max-width: 500rpx;
  font-size: 20rpx;
  line-height: 1.45;
  color: #637d70;
}

.code-preview-button {
  width: 220rpx !important;
  height: 66rpx;
  margin: 24rpx auto 0;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  line-height: 1;
  font-weight: 900;
  color: #fff;
  background: #19845e;
}

.empty-state {
  margin-top: 22rpx;
}

.empty-gift {
  width: 74rpx;
  height: 74rpx;
  margin: 0 auto 15rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  color: #9a792c;
  background: #fff0c8;
}

.ticket-spotlight-overlay {
  position: fixed;
  inset: 0;
  z-index: 999;
  min-height: 100vh;
  padding: 180rpx 34rpx 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(13, 50, 33, 0.52);
  backdrop-filter: blur(8rpx);
  animation: ticketMaskIn 220ms ease-out both;
}

.ticket-spotlight-card {
  position: relative;
  width: 100%;
  max-width: 680rpx;
  padding: 34rpx 28rpx 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 26rpx;
  overflow: hidden;
  text-align: center;
  background: linear-gradient(180deg, #f5fff5 0%, #e4f8e7 100%);
  box-shadow: 0 34rpx 80rpx rgba(7, 63, 38, 0.34);
  animation: ticketCardPop 520ms cubic-bezier(0.2, 0.9, 0.18, 1.12) both;
}

.ticket-spotlight-card::before {
  content: "";
  position: absolute;
  inset: -90rpx -40rpx auto;
  height: 220rpx;
  background: radial-gradient(circle, rgba(248, 221, 105, 0.35) 0%, rgba(248, 221, 105, 0) 68%);
  animation: ticketHalo 1500ms ease-in-out infinite;
}

.ticket-spotlight-badge {
  position: relative;
  z-index: 2;
  width: 142rpx;
  height: 44rpx;
  margin: 0 auto 16rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 900;
  color: #fff;
  background: #19845e;
  box-shadow: 0 10rpx 24rpx rgba(25, 132, 94, 0.22);
}

.ticket-spotlight-stage {
  position: relative;
  z-index: 2;
  height: 270rpx;
  margin: 0 0 16rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #eaf7ed;
}

.ticket-spotlight-stage::after {
  content: "";
  position: absolute;
  top: -40rpx;
  bottom: -40rpx;
  width: 86rpx;
  transform: rotate(18deg);
  background: linear-gradient(90deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.74), rgba(255, 255, 255, 0));
  animation: ticketShine 1800ms ease-in-out 380ms infinite;
}

.ticket-spotlight-ring {
  position: absolute;
  width: 380rpx;
  height: 380rpx;
  border: 3rpx solid rgba(47, 160, 96, 0.22);
  border-radius: 50%;
  animation: ticketRingPulse 1300ms ease-out infinite;
}

.ticket-spotlight-image {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  animation: ticketFloat 2100ms ease-in-out infinite;
}

.ticket-spark {
  position: absolute;
  z-index: 3;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #f4d75d;
  box-shadow: 0 0 22rpx rgba(244, 215, 93, 0.8);
  animation: ticketSpark 1200ms ease-in-out infinite;
}

.ticket-spark-one {
  left: 72rpx;
  top: 54rpx;
}

.ticket-spark-two {
  right: 88rpx;
  top: 78rpx;
  animation-delay: 180ms;
}

.ticket-spark-three {
  right: 178rpx;
  bottom: 58rpx;
  animation-delay: 360ms;
}

.ticket-spotlight-title {
  position: relative;
  z-index: 2;
  margin-top: 8rpx;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #123d2b;
}

.ticket-spotlight-note {
  position: relative;
  z-index: 2;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.35;
  font-weight: 800;
  color: #33755b;
}

.ticket-spotlight-button {
  position: relative;
  z-index: 2;
  width: 250rpx !important;
  height: 68rpx;
  margin: 26rpx auto 0;
  padding: 0;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 900;
  color: #fff;
  background: #19845e;
  box-shadow: 0 16rpx 34rpx rgba(25, 132, 94, 0.26);
}

@keyframes ticketMaskIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes ticketCardPop {
  0% {
    opacity: 0;
    transform: translateY(80rpx) scale(0.9);
  }
  70% {
    opacity: 1;
    transform: translateY(-8rpx) scale(1.02);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes ticketHalo {
  0%, 100% {
    opacity: 0.55;
    transform: scale(0.96);
  }
  50% {
    opacity: 1;
    transform: scale(1.08);
  }
}

@keyframes ticketShine {
  0% {
    left: -140rpx;
    opacity: 0;
  }
  18%, 56% {
    opacity: 1;
  }
  76%, 100% {
    left: 760rpx;
    opacity: 0;
  }
}

@keyframes ticketRingPulse {
  0% {
    opacity: 0.72;
    transform: scale(0.82);
  }
  100% {
    opacity: 0;
    transform: scale(1.12);
  }
}

@keyframes ticketFloat {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-8rpx);
  }
}

@keyframes ticketSpark {
  0%, 100% {
    opacity: 0.35;
    transform: scale(0.75);
  }
  50% {
    opacity: 1;
    transform: scale(1.2);
  }
}
