.me-page {
  background: #f4f8f3;
}

.me-hero {
  min-height: 590rpx;
  background: linear-gradient(180deg, #d6f1e3 0%, #eff5db 100%);
}

.me-topbar {
  height: 100rpx;
  padding-right: 190rpx;
}

.me-title {
  font-size: 32rpx;
  font-weight: 900;
  white-space: nowrap;
}

.student-code-button {
  flex: none;
  width: 112rpx !important;
  min-width: 112rpx;
  max-width: 112rpx;
  height: 56rpx;
  border: 2rpx solid #abd3bd;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 800;
  color: #267454;
  background: rgba(255, 255, 255, 0.82);
}

.profile-card {
  position: relative;
  height: 255rpx;
  margin: 12rpx 28rpx 0;
  padding: 30rpx 24rpx;
  border-radius: 18rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  color: #fff;
  background: #197f5c;
  box-shadow: 0 15rpx 34rpx rgba(24, 111, 79, 0.18);
}

.profile-card::after {
  content: "";
  position: absolute;
  right: -60rpx;
  bottom: -80rpx;
  width: 270rpx;
  height: 170rpx;
  border: 14rpx solid rgba(255, 255, 255, 0.09);
  border-radius: 100% 0 100% 0;
  transform: rotate(-20deg);
}

.profile-avatar {
  position: relative;
  z-index: 2;
  flex: none;
  width: 126rpx;
  height: 126rpx;
  margin-right: 20rpx;
  border: 7rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  overflow: hidden;
  background: #e0f2d5;
}

.profile-avatar image {
  width: 100%;
  height: 100%;
  transform: scale(1.36) translateY(8rpx);
}

.profile-copy {
  position: relative;
  z-index: 2;
  min-width: 0;
  flex: 1;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 900;
}

.profile-college {
  margin-top: 10rpx;
  max-width: 280rpx;
  overflow: hidden;
  font-size: 19rpx;
  color: #d2ebdf;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-badge {
  display: inline-block;
  margin-top: 14rpx;
  padding: 7rpx 13rpx;
  border-radius: 20rpx;
  font-size: 17rpx;
  color: #6d5514;
  background: #f8dc72;
}

.profile-role {
  display: inline-block;
  margin-top: 10rpx;
  margin-left: 8rpx;
  padding: 7rpx 13rpx;
  border-radius: 20rpx;
  font-size: 17rpx;
  color: #e8f6ee;
  background: rgba(255, 255, 255, 0.14);
}

.profile-edit {
  position: absolute;
  top: 22rpx;
  right: 20rpx;
  z-index: 3;
  width: 80rpx !important;
  padding: 9rpx 15rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 24rpx;
  font-size: 17rpx;
  color: #e2f2eb;
  background: rgba(255, 255, 255, 0.08);
}

.profile-water {
  position: absolute;
  right: 20rpx;
  bottom: -80rpx;
  z-index: 2;
  width: 145rpx;
  height: 220rpx;
  opacity: 0.92;
  transform: rotate(7deg);
}

.stats-strip {
  height: 142rpx;
  margin: 18rpx 28rpx 0;
  border: 2rpx solid rgba(33, 111, 79, 0.08);
  border-radius: 16rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  background: rgba(255, 255, 255, 0.85);
}

.stats-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stats-item:not(:last-child)::after {
  content: "";
  position: absolute;
  top: 38rpx;
  right: 0;
  width: 2rpx;
  height: 66rpx;
  background: #e2ece6;
}

.stats-value {
  font-size: 30rpx;
  font-weight: 900;
  color: #187d59;
}

.stats-label {
  margin-top: 7rpx;
  font-size: 17rpx;
  color: #758b80;
}

.me-content {
  padding-top: 20rpx;
}

.pending-banner {
  min-height: 100rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  background: #fff0ca;
}

.pending-icon {
  flex: none;
  width: 60rpx;
  height: 60rpx;
  margin-right: 14rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 900;
  color: #9b6a18;
  background: #fff;
}

.pending-copy {
  min-width: 0;
  flex: 1;
}

.pending-title {
  font-size: 22rpx;
  font-weight: 800;
  color: #77561b;
}

.pending-note {
  margin-top: 6rpx;
  font-size: 17rpx;
  color: #987d4b;
}

.pending-arrow,
.menu-arrow {
  flex: none;
  font-size: 36rpx;
  color: #94a69d;
}

.menu-list {
  overflow: hidden;
}

.menu-row {
  min-height: 120rpx;
  padding: 20rpx;
  border-bottom: 2rpx solid #edf2ee;
  display: flex;
  align-items: center;
}

.menu-row:last-child {
  border-bottom: 0;
}

.menu-icon {
  flex: none;
  width: 72rpx;
  height: 72rpx;
  margin-right: 16rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.menu-copy {
  min-width: 0;
  flex: 1;
}

.menu-title {
  font-size: 24rpx;
  font-weight: 800;
}

.menu-note {
  margin-top: 7rpx;
  font-size: 18rpx;
  color: #7f9087;
}

.brand-footer {
  margin-top: 35rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 18rpx;
  color: #8a9b92;
}

.brand-footer image {
  width: 140rpx;
  height: 100rpx;
  margin-bottom: 8rpx;
  border-radius: 12rpx;
}
