.staff-page {
  background: #f5f8f4;
}

.staff-hero {
  min-height: 430rpx;
  color: #fff;
  background: #176f55;
}

.staff-topbar {
  height: 88rpx;
  padding: 0 190rpx 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.staff-title {
  font-size: 30rpx;
  font-weight: 900;
}

.staff-role {
  padding: 8rpx 13rpx;
  border-radius: 22rpx;
  font-size: 18rpx;
  color: #6f5514;
  background: #f7d668;
}

.staff-summary {
  min-height: 235rpx;
  margin: 35rpx 28rpx 0;
  padding: 30rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 17rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.09);
}

.staff-summary-main {
  min-width: 0;
  padding-right: 18rpx;
}

.staff-summary-label {
  font-size: 20rpx;
  color: #cce8dc;
}

.staff-summary-title {
  margin-top: 13rpx;
  max-width: 430rpx;
  font-size: 31rpx;
  line-height: 1.4;
  font-weight: 900;
}

.staff-summary-note {
  margin-top: 12rpx;
  font-size: 18rpx;
  color: #cce8dc;
}

.staff-count {
  flex: none;
  width: 118rpx;
  height: 118rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.staff-count view {
  font-size: 32rpx;
  font-weight: 900;
  color: #f6d76c;
}

.staff-count text {
  margin-top: 4rpx;
  font-size: 16rpx;
  color: #d3eadd;
}

.staff-content {
  margin-top: -26rpx;
  border-radius: 28rpx 28rpx 0 0;
  background: #f5f8f4;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.summary-card {
  min-height: 112rpx;
  padding: 18rpx 12rpx;
  border: 2rpx solid #e3eee7;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #fff;
}

.summary-value {
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 900;
  color: #17382b;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-label {
  margin-top: 6rpx;
  overflow: hidden;
  font-size: 17rpx;
  color: #7b8d83;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.staff-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.staff-action {
  width: 100% !important;
  min-height: 218rpx;
  padding: 25rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.staff-action-loading {
  opacity: 0.62;
}

.staff-action-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
}

.staff-action-title {
  margin-top: 20rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.staff-action-note {
  margin-top: 8rpx;
  font-size: 17rpx;
  line-height: 1.5;
  color: #7b8d83;
}

.staff-warning {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: flex-start;
  font-size: 19rpx;
  line-height: 1.55;
  color: #8a7548;
  background: #fff2ce;
}

.staff-warning-icon {
  flex: none;
  width: 48rpx;
  height: 48rpx;
  margin-right: 12rpx;
  border-radius: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17rpx;
  font-weight: 900;
  color: #926817;
  background: #fff;
}

.log-empty {
  padding: 42rpx 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: #789086;
}

.log-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.log-card {
  min-height: 126rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
}

.log-icon {
  flex: none;
  width: 62rpx;
  height: 62rpx;
  margin-right: 16rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  color: #267454;
  background: #e1f4e9;
}

.log-main {
  min-width: 0;
  flex: 1;
}

.log-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.log-title {
  overflow: hidden;
  font-size: 23rpx;
  font-weight: 900;
  color: #17382b;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-time {
  flex: none;
  font-size: 17rpx;
  color: #91a299;
}

.log-meta {
  margin-top: 7rpx;
  overflow: hidden;
  font-size: 18rpx;
  color: #789086;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.log-result {
  margin-top: 8rpx;
  display: inline-flex;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-size: 17rpx;
  color: #267454;
  background: #e1f4e9;
}

.audit-empty {
  padding: 54rpx 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: #789086;
}

.audit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.audit-card {
  min-height: 220rpx;
  padding: 18rpx;
  display: flex;
  align-items: stretch;
}

.audit-thumb {
  flex: none;
  width: 180rpx;
  height: 180rpx;
  margin-right: 18rpx;
  border-radius: 12rpx;
  background: #e5eee9;
}

.audit-main {
  min-width: 0;
  flex: 1;
}

.audit-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.audit-title {
  min-width: 0;
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 900;
  color: #17382b;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audit-status {
  flex: none;
  padding: 7rpx 12rpx;
  border-radius: 18rpx;
  font-size: 17rpx;
  color: #267454;
  background: #e1f4e9;
}

.audit-meta {
  margin-top: 8rpx;
  overflow: hidden;
  font-size: 18rpx;
  color: #789086;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audit-ai {
  display: inline-flex;
  margin-top: 12rpx;
  padding: 7rpx 12rpx;
  border-radius: 18rpx;
  font-size: 17rpx;
  color: #7a6120;
  background: #fff2ce;
}

.audit-ai-pass {
  color: #237653;
  background: #e1f4e9;
}

.audit-ai-reject {
  color: #9b5634;
  background: #fbe8df;
}

.audit-ai-manual {
  color: #5f7197;
  background: #e8edf8;
}

.audit-reason {
  margin-top: 8rpx;
  max-height: 64rpx;
  overflow: hidden;
  font-size: 18rpx;
  line-height: 1.45;
  color: #6d8177;
}

.audit-buttons {
  margin-top: 14rpx;
  display: flex;
  gap: 12rpx;
}

.audit-button {
  flex: 1;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  color: #fff;
}

.audit-button.approve {
  background: #1f9d63;
}

.audit-button.reject {
  background: #d96d50;
}

.audit-button[disabled] {
  color: #8da097;
  background: #dce8e2;
}
