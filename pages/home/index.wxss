  background: linear-gradient(145deg, #348eb0 0%, #216b87 100%);
}

.feature-mini::before,
.feature-mini::after {
  content: "";
  position: absolute;
  border-radius: 50% 0 50% 50%;
  background: rgba(210, 239, 166, 0.42);
  transform: rotate(42deg);
}

.feature-mini::before {
  top: 5rpx;
  left: 5rpx;
  width: 22rpx;
