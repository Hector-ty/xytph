.map-page {
  background: linear-gradient(180deg, #e1f2e8 0%, #f5f8f4 400rpx);
}

.map-topbar {
  height: 104rpx;
  padding-right: 190rpx;
}

.map-topbar > view:nth-child(2) {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.map-count {
  flex: none;
  padding: 9rpx 13rpx;
  border-radius: 22rpx;
  font-size: 17rpx;
  color: #287657;
  background: #fff;
}

.map-content {
  padding-top: 12rpx;
}

.map-filters {
  width: calc(100% + 56rpx);
  margin-left: -28rpx;
  white-space: nowrap;
}

.map-filter-inner {
  padding: 4rpx 28rpx 16rpx;
  display: inline-flex;
  gap: 10rpx;
}

.map-filter-inner button {
  width: auto !important;
  min-width: 86rpx;
  height: 54rpx;
  padding: 0 18rpx;
  border: 2rpx solid #d9e7df;
  border-radius: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  line-height: 1;
  color: #70877b;
  background: #fff;
  text-align: center;
  white-space: nowrap;
}

.map-filter-inner button.active {
  border-color: #21825e;
  font-weight: 800;
  color: #fff;
  background: #21825e;
}

.campus-map {
  position: relative;
  height: 414rpx;
  overflow: hidden;
  background: #fff;
}

.map-building {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 1;
}

.map-hotspot-layer {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.map-hotspot {
  position: absolute;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
}

.map-hotspot-active {
  border-color: rgba(24, 132, 94, 0.45);
  background: rgba(24, 132, 94, 0.12);
}

.map-pin {
  position: absolute;
  z-index: 3;
  width: 58rpx;
  height: 58rpx;
  margin: -29rpx 0 0 -29rpx;
  border: 5rpx solid #fff;
  border-radius: 50%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 900;
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(46, 89, 68, 0.28);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  transform-origin: center;
}

.map-pin-active {
  z-index: 4;
  transform: scale(1.08);
  box-shadow: 0 14rpx 26rpx rgba(46, 89, 68, 0.34);
}

.map-pin-label {
  display: none;
}

.location-list {
  overflow: hidden;
}

.location-row {
  min-height: 120rpx;
  padding: 18rpx 20rpx;
  border-bottom: 2rpx solid #edf2ee;
  display: flex;
  align-items: center;
}

.location-row:last-child {
  border-bottom: 0;
}

.location-icon {
  flex: none;
  width: 68rpx;
  height: 68rpx;
  margin-right: 14rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
}

.location-copy {
  min-width: 0;
  flex: 1;
}

.location-name {
  font-size: 23rpx;
  font-weight: 800;
}

.location-note {
  margin-top: 7rpx;
  overflow: hidden;
  font-size: 17rpx;
  color: #809087;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-type {
  flex: none;
  padding: 7rpx 12rpx;
  border-radius: 20rpx;
  font-size: 16rpx;
  color: #627a6e;
  background: #edf4ef;
}

.location-actions {
  flex: none;
  margin-left: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.location-nav {
  width: 92rpx !important;
  height: 46rpx;
  margin: 0;
  padding: 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 800;
  color: #fff;
  background: #19845e;
}
