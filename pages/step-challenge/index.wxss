page {
  height: 100%;
  overflow: hidden;
  background: #eef7f1;
}

.step-page {
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  background: #eef7f1;
}

.step-stage {
  position: relative;
  flex: 1 1 0;
  min-height: 620rpx;
  overflow: hidden;
  background: #dcefe4;
}

.step-stage-ended {
  flex: 1 1 0;
  height: auto;
  min-height: 660rpx;
}

.campus-live-map {
  width: 100%;
  height: 100%;
}

.steps-dock {
  flex: 0 0 auto;
  padding: 18rpx 28rpx calc(env(safe-area-inset-bottom) + 18rpx);
  border-radius: 26rpx 26rpx 0 0;
  display: flex;
  flex-direction: column;
  background: #f8fbf8;
  box-shadow: 0 -10rpx 28rpx rgba(26, 84, 58, 0.12);
}

.steps-dock-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.steps-label {
  font-size: 25rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #17382b;
}

.steps-sync {
  margin-top: 5rpx;
  font-size: 19rpx;
  color: #6c8176;
}

.sync-button,
.settings-button,
.home-button {
  flex: none;
  height: 54rpx;
  padding: 0 22rpx;
  border: 2rpx solid rgba(43, 155, 102, 0.24);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 800;
  color: #2b9b66;
  background: #eef8f3;
}

.steps-main {
  min-height: 86rpx;
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.steps-count {
  min-width: 0;
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.steps-value {
  max-width: 390rpx;
  overflow: hidden;
  font-size: 64rpx;
  line-height: 1;
  font-weight: 900;
  color: #17382b;
  text-overflow: ellipsis;
  white-space: nowrap;
  transform-origin: 50% 80%;
}

.steps-value-jump {
  animation: steps-value-jump 420ms ease-out;
}

@keyframes steps-value-jump {
  0% {
    transform: translateY(0) scale(1);
  }

  38% {
    transform: translateY(-8rpx) scale(1.08);
  }

  68% {
    transform: translateY(2rpx) scale(0.98);
  }

  100% {
    transform: translateY(0) scale(1);
  }
}

.steps-unit {
  margin-left: 10rpx;
  font-size: 23rpx;
  font-weight: 800;
  color: #5d796b;
}

.carbon-counter {
  flex: none;
  min-width: 156rpx;
  padding: 10rpx 14rpx;
  border: 2rpx solid rgba(43, 155, 102, 0.18);
  border-radius: 16rpx;
  background: #edf8f1;
}

.carbon-counter-value {
  max-width: 180rpx;
  overflow: hidden;
  font-size: 26rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #16835d;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.carbon-counter-label {
  margin-top: 4rpx;
  font-size: 18rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #5f7a6e;
  text-align: center;
}

.progress-track {
  height: 14rpx;
  margin: 12rpx 0 0;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dbece2;
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #31aa70 0%, #86c84d 100%);
}

.challenge-stats {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.stat-item {
  min-height: 78rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #edf7f1;
}

.stat-value {
  font-size: 24rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #17382b;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #668074;
}

.step-message {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 14rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #b05d28;
  background: #fff4e8;
}

.step-message.ok {
  color: #2b7656;
  background: #edf8f1;
}

.settings-button {
  width: 220rpx;
  margin: 14rpx 0 0;
}

.action-row {
  margin-top: 12rpx;
  padding-top: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.danger-button,
.action-button,
.home-button {
  flex: 1;
  height: 72rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.danger-button {
  color: #fff;
  background: #e16a4a;
  box-shadow: 0 12rpx 24rpx rgba(164, 64, 38, 0.18);
}

.action-button {
  margin: 0;
}

.home-button {
  color: #2b9b66;
  background: #eef8f3;
}

.challenge-result-layer {
  flex: none;
  min-height: 0;
  padding: 14rpx 28rpx calc(env(safe-area-inset-bottom) + 8rpx);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  background: #eaf6ee;
}

.challenge-result-card {
  flex: none;
  padding: 24rpx 24rpx 20rpx;
  border: 2rpx solid rgba(38, 129, 88, 0.12);
  border-radius: 22rpx;
  background: #fbfef9;
  box-shadow: 0 12rpx 32rpx rgba(18, 75, 52, 0.12);
}

.result-kicker {
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #16875a;
}

.result-title {
  margin-top: 6rpx;
  font-size: 38rpx;
  line-height: 1.12;
  font-weight: 900;
  color: #0e3a29;
}

.result-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #405f52;
}

.result-hero-row {
  margin-top: 16rpx;
  display: flex;
  gap: 10rpx;
}

.result-hero-item {
  flex: 1;
  min-width: 0;
  min-height: 90rpx;
  padding: 12rpx 8rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #e5f4e8;
}

.result-hero-value {
  max-width: 100%;
  overflow: hidden;
  font-size: 28rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #087044;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.result-hero-label {
  margin-top: 6rpx;
  font-size: 19rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #4f6c60;
}

.result-info-list {
  margin-top: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 18rpx;
  background-color: #eef7ee;
}

.result-info-row {
  min-height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.result-info-label {
  flex: none;
  width: 126rpx;
  font-size: 20rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #5e766b;
}

.result-info-value {
  min-width: 0;
  flex: 1;
  font-size: 21rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #103b2b;
  text-align: right;
  white-space: normal;
  word-break: break-all;
}

.result-claim-button,
.result-home-button {
  flex: none;
  width: 100%;
  height: 82rpx;
  margin: 20rpx 0 0;
  padding: 0;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 82rpx;
  font-weight: 900;
  text-align: center;
  color: #fff;
  background-color: #14995f;
  box-shadow: 0 14rpx 30rpx rgba(18, 112, 76, 0.28);
}

.result-claim-button {
  background-color: #d99a22;
  box-shadow: 0 14rpx 30rpx rgba(183, 118, 23, 0.24);
}

.result-claim-button[disabled] {
  color: #6f8077;
  background-color: #dce8e2;
  box-shadow: none;
}
